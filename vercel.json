{
  "version": 2,
  "name": "aerolive",
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/index.js"
    },
    {
      "src": "/socket.io/(.*)",
      "dest": "server/index.js"
    },
    {
      "src": "/static/(.*)",
      "dest": "client/static/$1"
    },
    {
      "src": "/manifest.json",
      "dest": "client/manifest.json"
    },
    {
      "src": "/favicon.ico",
      "dest": "client/favicon.ico"
    },
    {
      "src": "/(.*)",
      "dest": "client/$1",
      "check": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/fetch-flights",
      "schedule": "*/1 * * * *"
    }
  ]
}
