# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/aerolive

# JWT Secret
JWT_SECRET=aerolive_super_secret_jwt_key_change_in_production

# OpenSky Network API (FREE - no key needed for basic, or register at opensky-network.org)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# AviationStack API Key (get free key at aviationstack.com)
AVIATIONSTACK_KEY=your_aviationstack_key_here

# Client URL for CORS
CLIENT_URL=http://localhost:3000
